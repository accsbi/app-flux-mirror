  code { background:#16232a; padding:1px 5px; border-radius:4px; color:#9fd; font-size:12px; }
  img.thumb { height:150px; border:1px solid #2a3a40; border-radius:6px; cursor:zoom-in; vertical-align:middle; background:#000; margin:2px; }
  .meta { color:#9fb0b5; font-size:13px; }
  .fix { background:#13251a; border:1px solid #2f6b3f; border-radius:6px; padding:10px 14px; margin:8px 0; }
  .bug { background:#2a1414; border:1px solid #6b2f2f; border-radius:6px; padding:10px 14px; margin:8px 0; }
  #lb { display:none; position:fixed; inset:0; background:rgba(0,0,0,.9); z-index:99; align-items:center; justify-content:center; cursor:zoom-out; }
  #lb img { max-width:96vw; max-height:96vh; }
