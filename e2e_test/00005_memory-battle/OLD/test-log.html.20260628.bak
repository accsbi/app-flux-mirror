  th,td { border:1px solid #2a3a40; padding:6px 8px; vertical-align:top; }
  th { background:#16232a; color:#d4af37; }
  td.no { white-space:nowrap; font-weight:bold; color:#9fd; }
  .j { font-weight:bold; white-space:nowrap; }
